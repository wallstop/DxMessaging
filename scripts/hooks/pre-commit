#!/usr/bin/env node
"use strict";

const path = require("path");
const { spawnPlatformCommandSync } = require("../lib/shell-command");

function resolveRepoRoot() {
  const result = spawnPlatformCommandSync("git", ["rev-parse", "--show-toplevel"], {
    cwd: process.cwd(),
    encoding: "utf8",
    stdio: ["ignore", "pipe", "ignore"]
  });
  if (!result.error && result.status === 0 && result.stdout.trim().length > 0) {
    return result.stdout.trim();
  }
  return path.resolve(__dirname, "..", "..");
}

const REPO_ROOT = resolveRepoRoot();

function run(command, args) {
  const result = spawnPlatformCommandSync(command, args, {
    cwd: REPO_ROOT,
    stdio: "inherit"
  });

  if (result.error && result.error.code === "ENOENT") {
    process.stderr.write(`Unable to find required command '${command}'.\n`);
    return 127;
  }

  return typeof result.status === "number" ? result.status : 1;
}

function main() {
  process.stdout.write("Repairing hook Node tooling if needed...\n");
  const repairStatus = run(process.execPath, ["scripts/repair-node-tooling.js"]);
  if (repairStatus !== 0) {
    return repairStatus;
  }

  process.stdout.write("Running pre-commit stage hooks...\n");
  const firstStatus = run(process.execPath, [
    "scripts/ensure-pre-commit.js",
    "run",
    "--hook-stage",
    "pre-commit"
  ]);
  if (firstStatus === 0 || firstStatus === 127) {
    return firstStatus;
  }

  process.stdout.write("Pre-commit hooks changed files; retrying once after auto-fixes...\n");
  return run(process.execPath, [
    "scripts/ensure-pre-commit.js",
    "run",
    "--hook-stage",
    "pre-commit"
  ]);
}

if (require.main === module) {
  process.exit(main());
}

#!/usr/bin/env node
"use strict";

const path = require("path");
const childProcess = require("child_process");

function resolveRepoRoot() {
  const result = childProcess.spawnSync("git", ["rev-parse", "--show-toplevel"], {
    cwd: process.cwd(),
    encoding: "utf8",
    stdio: ["ignore", "pipe", "ignore"]
  });
  if (!result.error && result.status === 0 && result.stdout.trim().length > 0) {
    return result.stdout.trim();
  }
  return path.resolve(__dirname, "..", "..");
}

const REPO_ROOT = resolveRepoRoot();

function run(command, args) {
  return childProcess.spawnSync(command, args, {
    cwd: REPO_ROOT,
    stdio: "inherit"
  });
}

function runOptional(command, args) {
  const result = run(command, args);
  if (result.error && result.error.code === "ENOENT") {
    return 127;
  }
  return typeof result.status === "number" ? result.status : 1;
}

function main() {
  process.stdout.write("Syncing banner version...\n");
  const bannerStatus = runOptional(process.execPath, ["scripts/sync-banner-version-hook.js"]);
  if (bannerStatus !== 0) {
    process.stdout.write("Banner version sync failed (cosmetic only, continuing).\n");
  }

  const staged = childProcess.spawnSync(
    "git",
    ["diff", "--cached", "--name-only", "--diff-filter=ACMR"],
    {
      cwd: REPO_ROOT,
      encoding: "utf8"
    }
  );
  if (staged.error || staged.status !== 0) {
    return 0;
  }

  const skillChanged = String(staged.stdout || "")
    .split(/\r?\n/)
    .some(
      (file) =>
        file.startsWith(".llm/skills/") &&
        file !== ".llm/skills/index.md" &&
        file !== ".llm/skills/specification.md" &&
        !file.includes("/templates/")
    );

  if (!skillChanged) {
    return 0;
  }

  process.stdout.write("Skill files modified, regenerating index...\n");
  const indexStatus = runOptional(process.execPath, ["scripts/generate-skills-index.js"]);
  if (indexStatus !== 0) {
    return indexStatus;
  }

  return runOptional("git", ["add", ".llm/skills/index.md"]);
}

if (require.main === module) {
  process.exit(main());
}

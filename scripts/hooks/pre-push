#!/usr/bin/env node
"use strict";

const path = require("path");
const childProcess = require("child_process");
const { spawnPlatformCommandSync } = require("../lib/shell-command");

function resolveRepoRoot() {
  const result = childProcess.spawnSync("git", ["rev-parse", "--show-toplevel"], {
    cwd: process.cwd(),
    encoding: "utf8",
    stdio: ["ignore", "pipe", "ignore"]
  });
  if (!result.error && result.status === 0 && result.stdout.trim().length > 0) {
    return result.stdout.trim();
  }
  return path.resolve(__dirname, "..", "..");
}

const REPO_ROOT = resolveRepoRoot();

function run(command, args, envOverride) {
  const result = spawnPlatformCommandSync(command, args, {
    cwd: REPO_ROOT,
    stdio: "inherit",
    ...(envOverride ? { env: { ...process.env, ...envOverride } } : {})
  });

  if (result.error && result.error.code === "ENOENT") {
    process.stderr.write(`Unable to find required command '${command}'.\n`);
    return 127;
  }

  return typeof result.status === "number" ? result.status : 1;
}

function main() {
  process.stdout.write("Repairing hook Node tooling if needed...\n");
  const repairStatus = run(process.execPath, ["scripts/repair-node-tooling.js"]);
  if (repairStatus !== 0) {
    return repairStatus;
  }

  process.stdout.write("Ensuring pre-commit is available...\n");
  const preCommitStatus = run(process.execPath, ["scripts/ensure-pre-commit.js"]);
  if (preCommitStatus !== 0) {
    return preCommitStatus;
  }

  // DXMSG_DOCTOR_FAST=1 for the doctor call ONLY: it skips the two redundant
  // git-walk sections (working-tree state + changed documentation, ~1.0s) that
  // preflight:pre-push re-runs authoritatively below
  // (validate:untracked-policy + validate:changed-docs). This keeps the native
  // hook under the <1s bootstrap budget without weakening any gate. The repair
  // step above (which auto-heals the regenerable Jest cache) and ensure-pre-commit
  // are deliberately NOT given this env.
  process.stdout.write("Running hook environment doctor...\n");
  const doctorStatus = run("npm", ["run", "doctor"], { DXMSG_DOCTOR_FAST: "1" });
  if (doctorStatus !== 0) {
    return doctorStatus;
  }

  process.stdout.write("Running pre-push parity preflight...\n");
  return run("npm", ["run", "preflight:pre-push"]);
}

if (require.main === module) {
  process.exit(main());
}

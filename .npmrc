# npm fetch-retry tuning. The default retry count (2) and backoff window are
# tight enough that a transient connection reset against the npm registry surfaces as a hard
# install failure across 22+ CI call sites + every devcontainer rebuild. These
# settings raise the retry count and broaden the backoff so a transient
# registry network blip is absorbed without escalating to a workflow failure.
#
# Documented at: https://docs.npmjs.com/cli/v11/using-npm/config/#fetch-retries
#
# Pinned + lower-bounded by scripts/__tests__/npmrc-fetch-retries-contract.test.js
# (the test also asserts no subordinate .npmrc files override these settings).
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
